rules_version = '2';

// Aturan keamanan Firestore StudyFlow.
// Setiap user (sudah login) hanya boleh membaca/menulis DOKUMEN profilnya
// sendiri di koleksi `users/{uid}`. Lihat documentation/PROGRESS.md.
service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{uid} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == uid;
    }
  }
}
