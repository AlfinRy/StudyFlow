rules_version = '2';

// Aturan keamanan Firestore StudyFlow.
// - Profil: tiap user hanya akses dokumennya sendiri (users/{uid}). Field
//   sensitif (uid/email/createdAt) tidak boleh diubah; role divalidasi.
// - Forum: publik (baca) untuk user login; tulis dengan data valid.
//   replyCount topik boleh di-increment user mana pun (kolaboratif), namun
//   field identitas (authorId/title/content) tidak boleh berubah.
// Lihat documentation/PROGRESS.md.
service cloud.firestore {
  match /databases/{database}/documents {

    // ===== Helper: cek field string non-kosong =====
    function isNonEmptyStr(v) {
      return v is string && v.size() > 0;
    }

    // ===== Profil pengguna =====
    match /users/{uid} {
      allow read: if request.auth != null;

      // Tulis profil: hanya pemilik. Field identitas immutable; role divalidasi.
      allow write: if request.auth != null
        && request.auth.uid == uid
        // uid & email tidak boleh diubah (sumber kebenaran = Auth).
        && (!('uid' in request.resource.data.diff(resource.data).affectedKeys())
            || resource.data.uid == uid)
        && (!('email' in request.resource.data.diff(resource.data).affectedKeys())
            || resource.data.email == resource.data.email)
        // role hanya boleh nilai enum yang sah (jika disertakan).
        && (!('role' in request.resource.data)
            || request.resource.data.role in
              ['siswa', 'mahasiswa', 'guru', 'umum']);
    }

    // ===== Papan peringkat (leaderboard) =====
    // Tiap user hanya menulis doc miliknya (uid). Field uid/weekId immutable
    // (anti curi slot peringkat orang lain). Baca publik untuk user login.
    match /progress/{uid} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
        && request.auth.uid == uid
        && request.resource.data.uid == uid
        && isNonEmptyStr(request.resource.data.weekId)
        && request.resource.data.weeklyXp is int
        && request.resource.data.weeklyXp >= 0;
      allow update: if request.auth != null
        && request.auth.uid == uid
        && request.resource.data.uid == resource.data.uid
        && request.resource.data.weekId is string
        && request.resource.data.weeklyXp is int
        && request.resource.data.weeklyXp >= 0;
      allow delete: if false;
    }

    // ===== Forum diskusi (PRD §5.6) =====
    match /forum_topics/{topicId} {
      allow read: if request.auth != null;

      // Buat topik: harus login & authorId = uid sendiri + field wajib.
      allow create: if request.auth != null
        && request.resource.data.authorId == request.auth.uid
        && isNonEmptyStr(request.resource.data.title)
        && isNonEmptyStr(request.resource.data.content)
        // Anti-spam: batas panjang judul/isi.
        && request.resource.data.title.size() <= 120
        && request.resource.data.content.size() <= 10000;

      // Update: hanya untuk menambah replyCount (transaksi client). Field
      // identitas topik harus tetap sama.
      allow update: if request.auth != null
        && request.resource.data.authorId == resource.data.authorId
        && request.resource.data.title == resource.data.title
        && request.resource.data.content == resource.data.content;

      // Hapus topik: belum ada fitur hapus.
      allow delete: if false;

      // Balasan
      match /replies/{replyId} {
        allow read: if request.auth != null;
        allow create: if request.auth != null
          && request.resource.data.authorId == request.auth.uid
          && isNonEmptyStr(request.resource.data.content)
          && request.resource.data.content.size() <= 5000;
        allow update, delete: if false;
      }
    }
  }
}
